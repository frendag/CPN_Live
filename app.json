{
  "expo": {
    "name": "CPN Analytics Live",
    "slug": "cpn-live",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cpncompet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#001a33"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cpnnatation.competlive",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Non utilisé",
        "NSLocationWhenInUseUsageDescription": "Non utilisé",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001a33"
      },
      "package": "fr.cpnnatation.competlive",
      "versionCode": 2,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#001a33",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "CPN Live",
          "iosDisplayInForeground": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "17f6181a-7739-4674-ae06-5851621a18f7"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "frendag"
  }
}
