{
  "expo": {
    "name": "CPN Analytics Live",
    "slug": "cpn-live",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cpncompet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#001a33"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cpnnatation.competlive",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Non utilis\u00e9",
        "NSLocationWhenInUseUsageDescription": "Non utilis\u00e9",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001a33"
      },
      "package": "fr.cpnnatation.competlive",
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 23,
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b51961f8-836e-418d-944d-8b9622a7eeea"
      }
    }
  }
}
