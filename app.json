{
  "expo": {
    "name": "CPN Compét Live",
    "slug": "cpnlive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cpncompet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "cli": {
    "appVersionSource": "remote"
    },
    "build": {
    "preview": {
      "distribution": "internal"
      }
    }
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cpnnatation.competlive"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a8a"
      },
      "package": "fr.cpnnatation.competlive"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "1dbe0d36-85a2-4386-9cb8-19a02aafe544"
      }
    }
  }
}
